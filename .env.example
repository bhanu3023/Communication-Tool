# ------------------------------------------------------------------
# AI Communication Skills Trainer — environment configuration
# Copy to .env and fill in the values.
# ------------------------------------------------------------------

# --- Database ---
POSTGRES_DB=trainer
POSTGRES_USER=trainer
POSTGRES_PASSWORD=trainer
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/trainer

# --- Azure AD (REQUIRED — Microsoft login only) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# --- Application JWT ---
# REQUIRED: a long random string (>= 32 chars). The backend now REFUSES to start if
# this is missing, shorter than 32 chars, or still contains "change-me".
APP_JWT_SECRET=change-me-to-a-long-random-secret-value-at-least-32-chars
APP_JWT_EXPIRATION_MINUTES=480

# --- OpenAI (optional — mock fallback used if empty) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Audio model for real pronunciation scoring. NOTE: gpt-4o-audio-preview is retired
# (returns 404); use a current audio model such as gpt-audio-mini or gpt-audio.
OPENAI_AUDIO_MODEL=gpt-audio-mini

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8080/api
VITE_AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=
VITE_AZURE_REDIRECT_URI=http://localhost:5173
