# ==================================================================
# PRODUCTION environment template for the AI Communication Skills Trainer.
# Copy to .env on the production host and fill in the <PLACEHOLDER> values.
# The real .env is gitignored — NEVER commit filled-in secrets.
# ==================================================================

# --- Database ---
POSTGRES_DB=trainer
POSTGRES_USER=trainer
POSTGRES_PASSWORD=<STRONG-RANDOM-DB-PASSWORD>
# Keep host 'db' if using the bundled docker-compose Postgres service;
# otherwise point this at your managed database host.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/trainer

# --- Azure AD (REQUIRED — Microsoft login is the only sign-in) ---
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
# No client secret is used or needed (SPA + PKCE; the backend only validates the
# Microsoft ID token). Do NOT set AZURE_CLIENT_SECRET.

# --- Application JWT ---
# REQUIRED: a long random string (>= 32 chars). The backend REFUSES TO START if this
# is missing, shorter than 32 chars, or still contains "change-me".
APP_JWT_SECRET=<generate-a-64-char-random-secret>
APP_JWT_EXPIRATION_MINUTES=480

# --- CORS (backend) — MUST include the production frontend origin ---
APP_CORS_ORIGINS=https://aicommunication.cftools.live

# --- Dev-login bypass — MUST stay false in production ---
APP_DEV_LOGIN_ENABLED=false
VITE_DEV_LOGIN=false

# --- OpenAI ---
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o-mini
# NOTE: gpt-4o-audio-preview is retired (404). Use a current audio model.
OPENAI_AUDIO_MODEL=gpt-audio-mini

# --- Azure Speech (optional — leave empty to skip real pronunciation scoring) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- Frontend (Vite — these are baked in at BUILD time) ---
# Point at the PRODUCTION backend URL, NOT localhost. Adjust the host/path to match
# how the backend is exposed (same domain behind a proxy, or a separate host).
VITE_API_BASE_URL=https://aicommunication.cftools.live/api
VITE_AZURE_TENANT_ID=<your-tenant-id>
VITE_AZURE_CLIENT_ID=<your-client-id>
# VITE_AZURE_REDIRECT_URI is no longer used — the app redirects to its own origin at
# runtime. Just register the production origin below as a Single-page application (SPA)
# redirect URI in the Azure app registration:
#     https://aicommunication.cftools.live
VITE_SPEAKING_AUDIO=false
